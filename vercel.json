{
  "version": 2,
  "routes": [
    { "src": "/playable-worlds", "dest": "/playable-worlds.html" },
    { "src": "/token", "dest": "/token.html" },
    { "src": "/whitepaper", "dest": "/whitepaper.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
