{
  "version": 2,
  "trailingSlash": false,
  "cleanUrls": true,
  "routes": [
    { "src": "/satoshi", "dest": "/satoshi.html" },
    { "src": "/cyberdeck", "dest": "/cyberdeck.html" },
    { "src": "/cyberdeck/a", "dest": "/cyberdeck-a.html" },
    { "src": "/cyberdeck-a", "dest": "/cyberdeck-a.html" },
    { "src": "/satoshi/claim", "dest": "/satoshi-claim.html" },
    { "src": "/playable-worlds", "dest": "/playable-worlds.html" },
    { "src": "/token", "dest": "/token.html" },
    { "src": "/frameworks", "dest": "/frameworks.html" },
    { "src": "/frameworks/entropy-surface", "dest": "/frameworks/entropy-surface.html" },
    { "src": "/frameworks/validation-distance", "dest": "/frameworks/validation-distance.html" },
    { "src": "/frameworks/network-relativity", "dest": "/frameworks/network-relativity.html" },
    { "src": "/frameworks/memetic-economics", "dest": "/frameworks/memetic-economics.html" },
    { "src": "/frameworks/learning-sandwich", "dest": "/frameworks/learning-sandwich.html" },
    { "src": "/app", "dest": "/app.html" },
    { "src": "/benchmark", "dest": "/benchmark.html" },
    { "src": "/human-os", "dest": "/human-os.html" },
    { "src": "/human-os/generate", "dest": "/human-os-generate.html" },
    { "src": "/human-os/leo", "dest": "/human-os-leo.html" },
    { "src": "/human-os/leaderboard", "dest": "/human-os-leaderboard.html" },
    { "src": "/.well-known/farcaster.json", "dest": "/.well-known/farcaster.json" },
    { "src": "/demo", "dest": "/demo.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/farcaster.json",
      "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
    },
    {
      "source": "/satoshi",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/satoshi/claim",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=*" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }]
    }
  ]
}
